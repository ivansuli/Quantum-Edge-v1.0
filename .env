# ============================================
# TRADING SYSTEM - CONFIGURACIÓN DE ENTORNO
# ============================================

# Seguridad
WEBHOOK_SECRET=tu_secreto_webhook_seguro_aqui
API_KEY_INTERNAL=tu_api_key_interna

# APIs Externas de Datos
ALPHA_VANTAGE_API_KEY=tu_alpha_vantage_key
POLYGON_API_KEY=tu_polygon_key
FRED_API_KEY=tu_fred_key
FINNHUB_API_KEY=tu_finnhub_key

# Broker (ejemplo con Alpaca)
BROKER_API_KEY=tu_broker_key
BROKER_SECRET_KEY=tu_broker_secret
BROKER_BASE_URL=https://paper-api.alpaca.markets

# Base de Datos
DATABASE_URL=sqlite+aiosqlite:///./data/trading.db

# Configuración de Riesgo
MAX_RISK_PER_TRADE=0.02
MIN_REWARD_RATIO=2.0
MAX_PORTFOLIO_CORRELATION=0.85
MIN_WIN_PROBABILITY=0.65
MAX_OPEN_POSITIONS=10
TOTAL_CAPITAL=100000.0

# ML Model
MODEL_PATH=./data/model_latest.joblib
RETRAIN_INTERVAL_HOURS=24

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
